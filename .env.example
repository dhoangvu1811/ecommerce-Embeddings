# =============================================================================
# ecommerce-Embeddings — biến môi trường (mẫu đầy đủ)
# Sao chép: copy .env.example .env   rồi chỉnh giá trị. Không commit file .env.
# =============================================================================

# --- Máy chỉ Uvicorn / FastAPI ---
API_HOST=0.0.0.0
API_PORT=8030

# --- Môi trường chạy embeddings service ---
# local/dev/production => Sentence Transformers
APP_ENV=local

# --- PostgreSQL (cùng DB với Commerce-Api / ecommerce-recomendation) ---
# Dùng khi index/reindex sản phẩm từ bảng products.
DATABASE_URL=postgresql://user:password@localhost:5432/commerce_db?schema=public

# --- Backend embedding ---
# local = sentence-transformers trên máy (offline)
EMBEDDING_BACKEND=local

# Model Hugging Face khi EMBEDDING_BACKEND=local (thuần Việt, 768 chiều)
EMBEDDING_LOCAL_MODEL=bkai-foundation-models/vietnamese-bi-encoder

# Cố định số chiều vector (phải khớp model và collection Qdrant).
EMBEDDING_VECTOR_SIZE=768

# Thiết bị embedding: auto | cpu | cuda
EMBEDDING_DEVICE=auto

# --- Qdrant ---
# Local Docker thường là cổng 6333. Qdrant Cloud: URL + API key từ dashboard.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=products_v1
QDRANT_IMAGE_COLLECTION=products_images_v1

# CLIP image search (enabled default)
CLIP_ENABLED=true

# --- Bảo vệ POST /v1/index/reindex ---
# Nếu đặt khác rỗng, request phải có header X-Reindex-Key trùng giá trị này.
# Khớp với EMBEDDINGS_REINDEX_SECRET trên Commerce-Api (nếu bật reindex từ API).
EMBEDDINGS_REINDEX_SECRET=

# --- URL storefront (ghép link sản phẩm trong payload Qdrant) ---
# Ví dụ clientEC dev: http://localhost:3000 hoặc port Next.js của bạn.
STORE_PUBLIC_URL=http://localhost:3000

# --- Chunking văn bản khi index (tùy chỉnh) ---
# Độ dài tối đa mỗi chunk; overlap giữa hai chunk liên tiếp (ký tự).
CHUNK_MAX_CHARS=600
CHUNK_OVERLAP=80

# --- Batch embedding khi index/reindex ---
# Giảm số text gửi mỗi request tới provider để tránh token limit khi catalog lớn.
EMBEDDING_BATCH_SIZE=32
