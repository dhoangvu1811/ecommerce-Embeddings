# Server
API_HOST=0.0.0.0
API_PORT=8030

# Same PostgreSQL as Commerce-Api / ecommerce-recomendation
DATABASE_URL=postgresql://user:password@localhost:5432/commerce_db?schema=public

# embedding: "local" (sentence-transformers, offline) or "protonx" (API)
EMBEDDING_BACKEND=local
# Model id for HuggingFace / sentence-transformers (multilingual, 384 dims)
EMBEDDING_LOCAL_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Override vector size if you change model (must match Qdrant collection)
# EMBEDDING_VECTOR_SIZE=384

# ProtonX cloud (only if EMBEDDING_BACKEND=protonx)
# PROTONX_API_KEY=
# PROTONX_EMBEDDINGS_URL=https://embeddings.protonx.io

# Qdrant (docker-compose.rag.yml exposes 6333)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=products_v1

# Protect POST /v1/index/reindex (match Commerce-Api EMBEDDINGS_REINDEX_SECRET)
EMBEDDINGS_REINDEX_SECRET=

# Public storefront base URL for product links in Qdrant payload
STORE_PUBLIC_URL=http://localhost:3000
